generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// role: "PARENT" | "CHILD"
// householdCode: random per-parent code that gates the public child lookup (parents only)
// pinHash: bcrypt hash of a child's 4-digit PIN (children only)
// pinFailedAttempts / pinLockedUntil: per-child PIN lockout state
model User {
  id                String    @id @default(cuid())
  name              String
  email             String?   @unique
  householdCode     String?   @unique
  pinHash           String?
  pinFailedAttempts Int       @default(0)
  pinLockedUntil    DateTime?
  passwordHash      String?
  role              String    @default("CHILD")
  parentId          String?
  parent            User?     @relation("Family", fields: [parentId], references: [id])
  children          User[]    @relation("Family")
  createdAt         DateTime  @default(now())

  assignedTasks  Task[]          @relation("AssignedTo")
  createdTasks   Task[]          @relation("CreatedBy")
  transactions   Transaction[]
  trustedDevices TrustedDevice[] @relation("HouseholdDevices")
  rememberedOn   TrustedDevice[] @relation("RememberedChildren")
  savingsGoals   SavingsGoal[]   @relation("ChildGoals")
  createdGoals   SavingsGoal[]   @relation("CreatedGoals")

  @@index([parentId])
}

// A physical device a household has chosen to trust for passwordless child re-login.
// tokenHash: bcrypt hash of the opaque device token stored in the client cookie.
// children: the children who have opted to be remembered (one-tap login) on this device.
model TrustedDevice {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  parentId   String
  parent     User     @relation("HouseholdDevices", fields: [parentId], references: [id])
  label      String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  expiresAt  DateTime
  children   User[]   @relation("RememberedChildren")

  @@index([parentId])
}

// status: "PENDING" | "COMPLETED" | "APPROVED" | "REJECTED"
// recurrence: "DAILY" | "WEEKLY" | "MONTHLY"
// weeklyDays: comma-separated day numbers 0-6 (0=Sun..6=Sat) for WEEKLY tasks; null/empty = every 7 days
// isUpForGrabs + assignedToId encode three states (the flag stays true even after a claim):
//   normal task   -> isUpForGrabs=false, assignedToId set
//   open pool      -> isUpForGrabs=true,  assignedToId=null (visible to the whole household)
//   grabbed/locked -> isUpForGrabs=true,  assignedToId set  (behaves like a normal task)
// An open chore's household is derived from createdById (always the parent).
// isPerUnit chores are paid by the item and split across the household. They use
// two row kinds linked by templateId (dollarAmount stays null on both):
//   definition  -> isPerUnit=true, isUpForGrabs=true, assignedToId=null, status=PENDING,
//                  unitReward set, quantity=null. Stays open in the pool forever; any
//                  child logs against it. Never completed or credited itself.
//   completion  -> isPerUnit=true, assignedToId=<kid>, quantity=N, unitReward inherited,
//                  status=COMPLETED->APPROVED. One per logged count; credits unitReward*quantity.
model Task {
  id           String   @id @default(cuid())
  title        String
  description  String?
  dollarAmount Int? // integer cents (e.g. 250 = $2.50)
  status       String   @default("PENDING")
  isUpForGrabs Boolean  @default(false)

  isPerUnit  Boolean @default(false)
  unitReward Int? // per-item reward in integer cents (per-unit definition + inherited by completions)
  quantity   Int? // units logged on a per-unit completion instance; null on the definition

  assignedToId String?
  assignedTo   User?  @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdById  String
  createdBy    User   @relation("CreatedBy", fields: [createdById], references: [id])

  dueDate     DateTime?
  completedAt DateTime?
  approvedAt  DateTime?

  isRecurring Boolean @default(false)
  recurrence  String?
  weeklyDays  String?
  // catchUp: when true on a child-assigned recurring task, missed occurrences are
  // backfilled as independent PENDING instances on read (see routes/tasks.ts).
  // Meaningful only for recurring, assigned, non-up-for-grabs tasks; false otherwise.
  catchUp     Boolean @default(false)
  templateId  String?
  template    Task?   @relation("Instances", fields: [templateId], references: [id])
  instances   Task[]  @relation("Instances")

  createdAt   DateTime     @default(now())
  transaction Transaction?

  @@index([assignedToId])
  @@index([createdById])
  @@index([dueDate])
  @@index([templateId])
}

// type: "EARNED" | "ADJUSTMENT" | "REDEEMED"
// REDEEMED: a negative entry from cashing in a savings goal (linked via goalId).
model Transaction {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id])
  taskId    String?      @unique
  task      Task?        @relation(fields: [taskId], references: [id])
  goalId    String?      @unique
  goal      SavingsGoal? @relation(fields: [goalId], references: [id])
  amount    Int // integer cents; negative for deductions
  type      String
  note      String?
  createdAt DateTime     @default(now())

  @@index([userId])
}

// status: "ACTIVE" | "REDEEM_REQUESTED" | "REDEEMED"
// A parent-set savings target for a child. Progress is DERIVED (the child's
// balance vs targetAmount) and never stored; a goal touches money only once, at
// cash-in approval, which writes a single negative REDEEMED transaction.
// targetAmount is integer cents (like Task.dollarAmount).
// At most one non-redeemed goal per child is enforced in the API, not the
// schema, so multiple goals (sharing the one balance pool) can be enabled later.
model SavingsGoal {
  id           String       @id @default(cuid())
  childId      String
  child        User         @relation("ChildGoals", fields: [childId], references: [id])
  createdById  String
  createdBy    User         @relation("CreatedGoals", fields: [createdById], references: [id])
  title        String
  targetAmount Int
  status       String       @default("ACTIVE")
  createdAt    DateTime     @default(now())
  redeemedAt   DateTime?
  transaction  Transaction?

  @@index([childId])
  @@index([createdById])
}
